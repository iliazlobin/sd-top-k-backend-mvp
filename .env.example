# Top-K MVP — environment configuration
# Copy to .env and fill with your values.
# DO NOT commit .env to version control.

# PostgreSQL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://topk:topk@localhost:5432/topk

# Redis
REDIS_URL=redis://localhost:6379/0

# Server port
APP_PORT=8000

# Count-Min Sketch parameters
CMS_EPSILON=0.01
CMS_DELTA=0.001

# Space-Saving capacity
SPACE_SAVING_CAPACITY=1000

# Bloom filter parameters
BLOOM_CAPACITY=10000000
BLOOM_ERROR_RATE=0.001

# Trending refresh interval (seconds)
REFRESH_INTERVAL_SECONDS=30
