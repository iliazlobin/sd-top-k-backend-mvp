# Top-K MVP — host e2e manifest
# Sources by the host e2e loop and CI e2e job.
# Do NOT embed secret values here; use env vars or .env.

MODE=docker
UP=docker compose up -d --build
READY=curl -s http://localhost:${PORT:-8010}/healthz
ACCEPTANCE=pytest verify/acceptance/ -v
DOWN=docker compose down -v
LOGS=docker compose logs --tail=100
TEST_DEPS="httpx pytest"
PORT=8010
BOARD=projects
